{
  "plugins": {},
  "filters": {
    "comments": true
  },
  "rules": {
    "preset-ja-technical-writing": {
      "ja-no-weak-phrase": false,
      "ja-no-mixed-period": {
        "allowPeriodMarks": [":"]
      },
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "",
        "preferInList": "",
        "strict": false
      },
      "no-exclamation-question-mark": false,
      "no-doubled-joshi": false
    },
    "terminology": {
      "exclude": [
        "V[ -]?S[ -]?Code"
      ]
    }
  }
}

{

    "textlint.configPath": "~/ghq/github.com/fenril058/zenn-content/.config/textlintrc.json",
    "markdownlint.configFile": "~/ghq/github.com/fenril058/zenn-content/.config/.markdownlint-cli2.jsonc",

    "udon.baseDirectories": [
        ["articles/*.md", "${workspaceFolder}/images/$fileBasenameNoExtension"]
    ],
    "udon.rule": [
        ["articles/*.md", "![](/${relImage:${workspaceFolder}})"],
        ["*.md", "![](${relImage})"],
        ["*", "${relImage:${workspaceFolder}}"]
    ]
}
